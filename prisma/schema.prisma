// This is your Prisma schema file.
// Learn more about it at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------
// TENANT
// ---------------------------------------------
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  projects       Project[]
  seats          Seat[]
  allocationLogs AllocationLog[]

  @@map("tenants")
}

// ---------------------------------------------
// USER
// ---------------------------------------------
model User {
  id           String   @id @default(cuid())
  tenantId     String
  employeeCode String
  name         String
  email        String
  role         UserRole @default(EMPLOYEE)
  jobTitle     String   @default("")
  department   String   @default("")
  status       String   @default("Active")
  joinDate     String   @default("")
  passwordHash String?
  lastLoginAt  DateTime?
  projectId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  seatAssignment SeatAssignment?

  @@unique([tenantId, employeeCode])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([projectId])
  @@index([tenantId, status])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

// ---------------------------------------------
// PROJECT
// ---------------------------------------------
model Project {
  id         String   @id @default(cuid())
  tenantId   String
  code       String
  name       String
  lead       String
  targetZone String
  color      String   @default("#3b82f6")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members User[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("projects")
}

// ---------------------------------------------
// SEAT
// ---------------------------------------------
model Seat {
  id        String     @id @default(cuid())
  tenantId  String
  label     String
  floor     Int
  zone      String
  number    Int
  type      SeatType   @default(REGULAR)
  status    SeatStatus @default(AVAILABLE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignment SeatAssignment?

  @@unique([tenantId, label])
  @@unique([tenantId, floor, zone, number])
  @@index([tenantId, floor, zone])
  @@index([status])
  @@map("seats")
}

enum SeatType {
  REGULAR
  HOT_DESK
  ACCESSIBLE
  PRIVATE
  MEETING_ROOM
}

enum SeatStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

// ---------------------------------------------
// SEAT ASSIGNMENT
// ---------------------------------------------
model SeatAssignment {
  id         String    @id @default(cuid())
  userId     String    @unique
  seatId     String    @unique
  assignedAt DateTime  @default(now())
  releasedAt DateTime?
  assignedBy String?
  notes      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  seat Seat @relation(fields: [seatId], references: [id], onDelete: Cascade)

  @@index([seatId])
  @@map("seat_assignments")
}

// ---------------------------------------------
// ALLOCATION LOG
// ---------------------------------------------
model AllocationLog {
  id            String   @id @default(cuid())
  tenantId      String
  employeeCode  String
  employeeName  String
  action        String
  seatLabel     String?
  prevSeatLabel String?
  details       String
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt(sort: Desc)])
  @@map("allocation_logs")
}
